# 本番の確定オリジン（SEO の metadataBase・canonical・OG 用）。例: https://www.example.com
NEXT_PUBLIC_APP_URL=

# お問い合わせページに埋め込むフォーム URL（Google Form の embed URL など）
NEXT_PUBLIC_CONTACT_FORM_EMBED_URL=

#（任意）エージェント検索 API `POST /api/agent/search` 用シークレット。
# 設定時は `Authorization: Bearer <値>` または `X-API-Key` で渡す。未設定のときは本番では常に拒否、非 production のみキー省略可。
AGENT_SEARCH_API_KEY=
